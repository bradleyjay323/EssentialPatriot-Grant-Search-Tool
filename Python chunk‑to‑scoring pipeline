# ---------- 1. Scoring Engine (from earlier) ----------

class VeteranHousingGrantScorer:
    def __init__(self):
        self.weights = {
            "eligibility": {
                "populationEligibility": {True: 10, False: 0},
                "housingModelAlignment": {True: 10, False: 0},
                "facilityRequirementsMet": {True: 5, False: 0}
            },
            "programFit": {
                "caseManagementAlignment": {
                    "strong": 10, "moderate": 6, "weak": 3, "none": 0
                },
                "supportiveServicesAlignment": {
                    "strong": 10, "moderate": 6, "weak": 3, "none": 0
                },
                "partnershipStrength": {
                    "strong": 5, "moderate": 3, "weak": 1, "none": 0
                }
            },
            "organizationalCapacity": {
                "staffingCapacity": {
                    "high": 10, "medium": 6, "low": 2
                },
                "facilityReadiness": {
                    "ready": 5, "partial": 3, "not_ready": 0
                },
                "pastPerformance": {
                    "strong": 5, "moderate": 3, "weak": 1, "none": 0
                }
            },
            "financialFit": {
                "awardAdequacy": {
                    "adequate": 10, "tight": 6, "insufficient": 0
                },
                "matchFeasibility": {
                    "feasible": 5, "challenging": 2, "not_feasible": 0
                }
            },
            "strategicValue": {
                "missionAlignment": {
                    "strong": 5, "moderate": 3, "weak": 1
                },
                "sustainabilityPotential": {
                    "high": 5, "medium": 3, "low": 1
                },
                "competitiveLandscape": {
                    "favorable": 5, "neutral": 3, "unfavorable": 1
                }
            }
        }

        self.thresholds = [
            (85, "High Priority"),
            (70, "Viable"),
            (50, "Low Fit"),
            (0, "Not Recommended")
        ]

    def score(self, grant: Dict[str, Any]) -> Dict[str, Any]:
        breakdown = {}
        for category, rules in self.weights.items():
            category_score = 0
            for field, scoring_table in rules.items():
                value = grant.get(field)
                if value in scoring_table:
                    category_score += scoring_table[value]
            breakdown[category] = category_score

        total_score = sum(breakdown.values())
        rating = next(label for threshold, label in self.thresholds if total_score >= threshold)

        return {
            "totalScore": total_score,
            "breakdown": breakdown,
            "rating": rating
        }


# ---------- 2. Data Structures ----------

@dataclass
class NOFOChunk:
    chunk_id: str
    section: str
    title: str
    text: str


# ---------- 3. Preprocessing & Chunking ----------

class NOFOPreprocessor:
    def preprocess(self, raw_text: str) -> str:
        text = raw_text.replace("\r", "\n")
        text = re.sub(r"\n{2,}", "\n\n", text)
        return text.strip()


class NOFOChunker:
    SECTION_PATTERN = re.compile(
        r"(Section\s+[IVXLC]+\.?\s+.+)", re.IGNORECASE
    )

    def chunk(self, text: str) -> List[NOFOChunk]:
        sections = self.SECTION_PATTERN.split(text)
        chunks: List[NOFOChunk] = []

        if not sections:
            return [NOFOChunk("GEN-1", "GENERAL", "Full NOFO", text)]

        # sections looks like: ["", "Section I ...", "text...", "Section II ...", "text...", ...]
        current_section = "GENERAL"
        for i in range(1, len(sections), 2):
            header = sections[i].strip()
            body = sections[i + 1].strip() if i + 1 < len(sections) else ""
            section_id = header.split()[1].rstrip(".")
            chunk_id = f"{section_id}-1"
            chunks.append(
                NOFOChunk(
                    chunk_id=chunk_id,
                    section=section_id,
                    title=header,
                    text=body
                )
            )
        return chunks


