# ---------- 5. Global Synthesis ----------

class NOFOSynthesizer:
    def synthesize(self, chunk_outputs: List[Dict[str, Any]]) -> Dict[str, Any]:
        unified = {
            "eligibility": [],
            "housingRequirements": {},
            "serviceModel": {},
            "requiredAttachments": [],
            "scoringCriteria": {},
            "budgetRequirements": {}
        }

        for out in chunk_outputs:
            unified["eligibility"].extend(out.get("eligibility", []))
            unified["requiredAttachments"].extend(out.get("requiredAttachments", []))

            # Simple merge; in production you’d handle conflicts more carefully
            unified["housingRequirements"].update(out.get("housingRequirements", {}))
            unified["serviceModel"].update(out.get("serviceModel", {}))
            unified["scoringCriteria"].update(out.get("scoringCriteria", {}))
            unified["budgetRequirements"].update(out.get("budgetRequirements", {}))

        # Deduplicate attachments
        unified["requiredAttachments"] = sorted(set(unified["requiredAttachments"]))

        return unified


