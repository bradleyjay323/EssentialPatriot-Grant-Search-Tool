# ---------- 7. Pipeline Orchestrator ----------

class NOFOScoringPipeline:
    def __init__(
        self,
        preprocessor: Optional[NOFOPreprocessor] = None,
        chunker: Optional[NOFOChunker] = None,
        extractor: Optional[NOFOChunkExtractor] = None,
        synthesizer: Optional[NOFOSynthesizer] = None,
        normalizer: Optional[ScoringInputNormalizer] = None,
        scorer: Optional[VeteranHousingGrantScorer] = None
    ):
        self.preprocessor = preprocessor or NOFOPreprocessor()
        self.chunker = chunker or NOFOChunker()
        self.extractor = extractor or NOFOChunkExtractor()
        self.synthesizer = synthesizer or NOFOSynthesizer()
        self.normalizer = normalizer or ScoringInputNormalizer()
        self.scorer = scorer or VeteranHousingGrantScorer()

    def run(self, raw_nofo_text: str) -> Dict[str, Any]:
        # 1. Preprocess
        clean_text = self.preprocessor.preprocess(raw_nofo_text)

        # 2. Chunk
        chunks = self.chunker.chunk(clean_text)

        # 3. Chunk‑level extraction
        chunk_outputs = [self.extractor.extract_from_chunk(c) for c in chunks]

        # 4. Global synthesis
        unified_nofo = self.synthesizer.synthesize(chunk_outputs)

        # 5. Normalize to scoring input
        scoring_input = self.normalizer.normalize(unified_nofo)

        # 6. Score
        score_result = self.scorer.score(scoring_input)

        return {
            "chunks": [c.__dict__ for c in chunks],
            "unified_nofo": unified_nofo,
            "scoring_input": scoring_input,
            "score_result": score_result
        }


